@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">ASP.NET Calculator</h1>

    <div style="max-width: 320px; margin: 20px auto; padding: 20px; background: #333; border-radius: 15px; box-shadow: 0px 10px 20px rgba(0,0,0,0.3);">
        <form method="post">
            <input type="text" name="display" value="@Model.Display" readonly
                   style="width: 100%; height: 60px; text-align: right; font-size: 30px; margin-bottom: 15px; padding: 10px; background: #eee; border: none; border-radius: 5px;" />

            <input type="hidden" name="previousValue" value="@Model.PreviousValue" />
            <input type="hidden" name="currentOperator" value="@Model.CurrentOperator" />

            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;">
                @foreach (var btn in new[] { "C", "/", "*", "del", "7", "8", "9", "-", "4", "5", "6", "+", "1", "2", "3", "=", "0" })
                {
                    <button type="submit" name="button" value="@btn"
                            style="height: 60px; border-radius: 10px; border: none; font-size: 20px; font-weight: bold;
                                background: @(btn == "=" ? "#28a745" : (btn == "C" || btn == "del" ? "#dc3545" : "#555")); color: white;
                                grid-column: @(btn == "0" ? "span 2" : "span 1");
                                grid-row: @(btn == "=" ? "span 2" : "auto")">
                        @btn
                    </button>
                }
            </div>
        </form>
    </div>
</div>